<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <debug-overrides>
        <trust-anchors>
            <!-- در حالت دیباگ، گواهی‌های نصب شده توسط کاربر را بپذیر -->
            <certificates src="user" />
        </trust-anchors>
    </debug-overrides>

    <!-- اجازه عبور ترافیک HTTP برای آدرس‌های لوکال توسعه‌دهنده -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain> <!-- Emulator -->
        <domain includeSubdomains="true">10.12.65.99</domain>
        <domain includeSubdomains="true">192.168.1.53</domain>
    </domain-config>
</network-security-config>
